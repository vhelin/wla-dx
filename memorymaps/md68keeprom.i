;
; Sega Mega Drive/Genesis MC68000 Memory Map with serial EEPROM
;

.MEMORYMAP
DEFAULTSLOT 0
SLOT 0 START $000000 SIZE $200000 NAME "ROM-LO" ; 2MB ROM below EEPROM latch
SLOT 1 START $200000 SIZE       2 NAME "EEPROM" ; serial EEPROM SDA/SCL latch
SLOT 2 START $200002 SIZE $1FFFFE NAME "ROM-HI" ; remaining cartridge space
SLOT 3 START $A00000 SIZE   $2000 NAME "ZRAM"   ; 8KB Z80 RAM
SLOT 4 START $FF0000 SIZE  $10000 NAME "WRAM"   ; 64KB Work RAM
.ENDME
