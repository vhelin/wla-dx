;
; Agon MOS helper macros for eZ80 binaries
;

.DEFINE AGON_MOS_HEADER_OFFSET $40
.DEFINE AGON_MOS_HEADER_VERSION $00

.DEFINE AGON_MOS_RUNMODE_Z80 $00
.DEFINE AGON_MOS_RUNMODE_ADL $01

.MACRO AGON_MOS_EXEC_NAME ARGS NAME
  .DB \1, 0
.ENDM

.MACRO AGON_MOS_HEADER ARGS RUNMODE
  .DB "MOS"
  .DB AGON_MOS_HEADER_VERSION
  .DB \1
.ENDM

.MACRO AGON_MOS_HEADER_Z80
  AGON_MOS_HEADER AGON_MOS_RUNMODE_Z80
.ENDM

.MACRO AGON_MOS_HEADER_ADL
  AGON_MOS_HEADER AGON_MOS_RUNMODE_ADL
.ENDM