;
; Sega CD / Mega CD Main CPU register definitions
;

.DEFINE REG_MCD_MAIN_RESET        $A12000
.DEFINE REG_MCD_MAIN_MEMMODE      $A12002
.DEFINE REG_MCD_MAIN_CDCMODE      $A12004
.DEFINE REG_MCD_MAIN_HINT         $A12006
.DEFINE REG_MCD_MAIN_COMFLAGS     $A1200E
.DEFINE REG_MCD_MAIN_COM0         $A12010
.DEFINE REG_MCD_MAIN_COM2         $A12012
.DEFINE REG_MCD_MAIN_COM4         $A12014
.DEFINE REG_MCD_MAIN_COM6         $A12016
.DEFINE REG_MCD_MAIN_COM8         $A12018
.DEFINE REG_MCD_MAIN_COM10        $A1201A
.DEFINE REG_MCD_MAIN_COM12        $A1201C
.DEFINE REG_MCD_MAIN_COM14        $A1201E

.DEFINE MCD_MEMMODE_2M            $0000
.DEFINE MCD_MEMMODE_1M            $0004
.DEFINE MCD_MEMMODE_WORDRAM_MAIN  $0000
.DEFINE MCD_MEMMODE_WORDRAM_SUB   $0001

.MACRO MCD_MAIN_GIVE_WORDRAM_TO_SUB
  move.w #MCD_MEMMODE_WORDRAM_SUB, REG_MCD_MAIN_MEMMODE
.ENDM

.MACRO MCD_MAIN_TAKE_WORDRAM
  move.w #MCD_MEMMODE_WORDRAM_MAIN, REG_MCD_MAIN_MEMMODE
.ENDM
