;
; Neo Geo shared platform constants and helper macros
;

.DEFINE NEOGEO_P_FIXED_BANK          0
.DEFINE NEOGEO_P_BANKED_FIRST_BANK   1
.DEFINE NEOGEO_M1_FIXED_BANK         0

.DEFINE NG_EYECATCHER_SYSTEM         0
.DEFINE NG_EYECATCHER_GAME           1
.DEFINE NG_EYECATCHER_NONE           2

.DEFINE NG_SOUND_CMD_PREPARE_SWITCH  $01
.DEFINE NG_SOUND_CMD_EYECATCHER      $02
.DEFINE NG_SOUND_CMD_RESET           $03

.MACRO NG_68K_FIXED_ORG
  .BANK NEOGEO_P_FIXED_BANK SLOT 0
  .ORGA \1
.ENDM

.MACRO NG_68K_BANKED_ORG
  .BANK \1 SLOT 2
  .ORGA \2
.ENDM

.MACRO NG_Z80_FIXED_ORG
  .BANK NEOGEO_M1_FIXED_BANK SLOT 0
  .ORGA \1
.ENDM